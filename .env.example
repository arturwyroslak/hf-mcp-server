# Skopiuj: cp .env.example .env

# ─── WYMAGANE ────────────────────────────────────────────
# Token HF z uprawnieniami read+write
# https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── OPCJONALNE ──────────────────────────────────────────
HF_READ_ONLY=false          # true = tylko odczyt, brak zapisów
HF_ADMIN_MODE=false         # true = odblokuje usuwanie repo
HF_MAX_FILE_SIZE=104857600  # max rozmiar pliku w bajtach (100 MB)
HF_INFERENCE_TIMEOUT=30     # timeout inference API w sekundach

# ─── HTTP TRANSPORT ──────────────────────────────────────
MCP_HOST=0.0.0.0            # adres nasłuchu (0.0.0.0 = wszystkie interfejsy)
MCP_PORT=8000               # port HTTP serwera MCP
MCP_PATH=/mcp               # ścieżka endpointu MCP
