# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── REQUIRED ─────────────────────────────
# Your HuggingFace token (read+write scope)
# Get it at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── OPTIONAL ─────────────────────────────
# Set to true to allow only read operations (no writes/uploads)
HF_READ_ONLY=false

# Set to true to enable destructive operations (repo delete)
HF_ADMIN_MODE=false

# Max file size in bytes (default: 100 MB)
HF_MAX_FILE_SIZE=104857600

# Inference API timeout in seconds
HF_INFERENCE_TIMEOUT=30
